// Prisma schema for the 813BNB / Tampa Bay Lodging Corporation platform.
// Shared by apps/booking and apps/corporate via @813bnb/db.
// Provider: Neon Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Auth (NextAuth.js / Auth.js Prisma adapter)
// ---------------------------------------------------------------------------

enum UserRole {
  GUEST
  OWNER
  STAFF
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  passwordHash  String?
  role          UserRole  @default(GUEST)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  // Guest-side relations
  bookingsAsGuest Booking[]        @relation("GuestBookings")
  idVerification  IdVerification?

  // Owner-side relations
  ownedProperties Property[]        @relation("PropertyOwner")
  maintenanceReqs MaintenanceRequest[] @relation("RequestedBy")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// Properties, units, pricing, availability
// ---------------------------------------------------------------------------

enum PropertyType {
  STUDIO
  ONE_BEDROOM
  TWO_BEDROOM
  THREE_BEDROOM
  HOUSE
}

model Property {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  propertyType PropertyType
  neighborhood String
  addressLine1 String
  addressLine2 String?
  city         String       @default("Tampa")
  state        String       @default("FL")
  zip          String
  lat          Float?
  lng          Float?
  description  String       @db.Text
  amenities    String[]     @default([])
  isWaterfront Boolean      @default(false)
  isPetFriendly Boolean     @default(false)
  isLuxury     Boolean      @default(false)
  isDowntown   Boolean      @default(false)
  isSampleData Boolean      @default(true) // flag demo/seed listings until real inventory loads
  isPublished  Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  ownerId String?
  owner   User?  @relation("PropertyOwner", fields: [ownerId], references: [id])

  units             Unit[]
  images            PropertyImage[]
  reviews           Review[]
  maintenanceReqs   MaintenanceRequest[]

  @@index([neighborhood])
  @@index([propertyType])
  @@map("properties")
}

model PropertyImage {
  id            String  @id @default(cuid())
  propertyId    String
  url           String
  alt           String
  sortOrder     Int     @default(0)
  isPlaceholder Boolean @default(true)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model Unit {
  id           String   @id @default(cuid())
  propertyId   String
  name         String   // e.g. "Unit A" for multi-unit properties
  bedrooms     Int
  bathrooms    Float
  maxGuests    Int
  sizeSqft     Int?
  nightlyRate  Decimal  @db.Decimal(10, 2)
  weeklyRate   Decimal? @db.Decimal(10, 2)
  monthlyRate  Decimal? @db.Decimal(10, 2)
  cleaningFee  Decimal  @default(0) @db.Decimal(10, 2)
  minNights    Int      @default(1)
  instantBook  Boolean  @default(true)
  isPublished  Boolean  @default(false)

  property         Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings         Booking[]
  availabilityBlocks AvailabilityBlock[]
  maintenanceReqs  MaintenanceRequest[]
  ownerStatements  OwnerStatement[]

  @@index([propertyId])
  @@map("units")
}

// Manual blackout / owner-blocked dates. Booked date ranges are derived from
// confirmed Bookings; this table only covers blocks that aren't a booking
// (maintenance holds, owner personal use, channel-manager sync placeholder).
model AvailabilityBlock {
  id        String   @id @default(cuid())
  unitId    String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, startDate, endDate])
  @@map("availability_blocks")
}

// ---------------------------------------------------------------------------
// Bookings, payments, agreements
// ---------------------------------------------------------------------------

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum RateType {
  NIGHTLY
  WEEKLY
  MONTHLY
}

model Booking {
  id            String        @id @default(cuid())
  confirmationCode String     @unique
  unitId        String
  guestId       String
  checkIn       DateTime      @db.Date
  checkOut      DateTime      @db.Date
  guestCount    Int
  rateType      RateType
  subtotal      Decimal       @db.Decimal(10, 2)
  cleaningFee   Decimal       @default(0) @db.Decimal(10, 2)
  taxes         Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        BookingStatus @default(PENDING_PAYMENT)
  specialRequests String?     @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  unit  Unit @relation(fields: [unitId], references: [id])
  guest User @relation("GuestBookings", fields: [guestId], references: [id])

  payments  Payment[]
  agreement RentalAgreement?

  @@index([unitId, checkIn, checkOut])
  @@index([guestId])
  @@map("bookings")
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY
  CASH_APP_PAY
  ZELLE_MANUAL // manual instruction + admin reconciliation only, not an automated integration
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String
  method                PaymentMethod
  status                PaymentStatus @default(PENDING)
  amount                Decimal       @db.Decimal(10, 2)
  stripePaymentIntentId String?
  zelleReferenceNote    String? // e.g. "guest to send $X to zelle handle, ref confirmation code"
  reconciledByStaffId   String? // staff user id who manually confirmed a Zelle payment
  createdAt             DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("payments")
}

enum AgreementStatus {
  NOT_SENT
  SENT
  SIGNED
  DECLINED
}

model RentalAgreement {
  id         String          @id @default(cuid())
  bookingId  String          @unique
  provider   String          @default("docusign") // "docusign" | "hellosign"
  envelopeId String?
  status     AgreementStatus @default(NOT_SENT)
  signedAt   DateTime?
  documentUrl String?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("rental_agreements")
}

model IdVerification {
  id           String   @id @default(cuid())
  userId       String   @unique
  documentUrl  String?
  status       String   @default("PENDING") // PENDING | VERIFIED | REJECTED
  submittedAt  DateTime @default(now())
  reviewedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("id_verifications")
}

// ---------------------------------------------------------------------------
// Owner portal
// ---------------------------------------------------------------------------

model OwnerStatement {
  id          String   @id @default(cuid())
  unitId      String
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date
  grossRevenue Decimal @db.Decimal(10, 2)
  fees         Decimal @db.Decimal(10, 2)
  netPayout    Decimal @db.Decimal(10, 2)
  statementUrl String?
  createdAt    DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, periodStart])
  @@map("owner_statements")
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model MaintenanceRequest {
  id          String            @id @default(cuid())
  propertyId  String
  unitId      String?
  requestedById String
  description String            @db.Text
  status      MaintenanceStatus @default(OPEN)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit        Unit?    @relation(fields: [unitId], references: [id])
  requestedBy User     @relation("RequestedBy", fields: [requestedById], references: [id])

  @@map("maintenance_requests")
}

// ---------------------------------------------------------------------------
// Reviews
// ---------------------------------------------------------------------------

enum ReviewSource {
  GOOGLE
  GUEST
  VIDEO
  AGENCY
}

model Review {
  id         String       @id @default(cuid())
  propertyId String?
  source     ReviewSource
  authorName String
  rating     Int
  body       String       @db.Text
  videoUrl   String?
  isFeatured Boolean      @default(false)
  createdAt  DateTime     @default(now())

  property Property? @relation(fields: [propertyId], references: [id])

  @@map("reviews")
}

// ---------------------------------------------------------------------------
// Leads (tampabaylodgingco.com forms: Sell Your House, Investors, Property
// Management, Government Housing, general Contact)
// ---------------------------------------------------------------------------

enum LeadType {
  SELL_YOUR_HOUSE
  INVESTOR
  PROPERTY_MANAGEMENT
  GOVERNMENT_HOUSING
  CORPORATE_HOUSING
  CONTACT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  ARCHIVED
}

enum InvestmentType {
  PARTNERSHIP
  SINGLE_UNIT
  MULTI_FAMILY
  ARBITRAGE
  OTHER
}

model Lead {
  id                    String          @id @default(cuid())
  type                  LeadType
  status                LeadStatus      @default(NEW)
  name                  String
  email                 String
  phone                 String
  city                  String?
  propertyAddress       String?
  amountAvailableToInvest Decimal?      @db.Decimal(12, 2)
  investmentType        InvestmentType?
  message               String?         @db.Text
  sourceSite            String          @default("tampabaylodgingco.com")
  sourcePage             String?
  createdAt             DateTime        @default(now())

  @@index([type, status])
  @@map("leads")
}
