# Copy this file to .env in the repo root for local dev (pnpm workspaces
# load a single root .env via Turborepo's globalDependencies), or set these
# per-project in Vercel's Environment Variables UI for deployed previews.
#
# Every integration below is optional in local/dev — the app falls back to a
# stubbed/sandbox mode when a key is missing, per apps/*/src/lib/env.ts.

# --- Database (Neon Postgres) -----------------------------------------------
# Neon gives you both a pooled and a direct connection string.
DATABASE_URL="postgresql://user:password@ep-example-pooler.us-east-1.aws.neon.tech/813bnb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.us-east-1.aws.neon.tech/813bnb?sslmode=require"

# --- NextAuth (apps/booking only — Client/Owner Portal login) --------------
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --- Cross-site links --------------------------------------------------------
# Set these to each app's Vercel preview/production URL once deployed.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_CORPORATE_SITE_URL="http://localhost:3001"   # used by apps/booking
NEXT_PUBLIC_BOOKING_SITE_URL="http://localhost:3000"     # used by apps/corporate

# --- Stripe (apps/booking) --------------------------------------------------
# Card, Apple Pay, Google Pay, and Cash App Pay all ride on Stripe. Leave
# blank to run checkout in sandbox/stub mode.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Zelle (apps/booking) ---------------------------------------------------
# Zelle has no merchant API — this only powers the "pay by Zelle" manual
# instructions shown at checkout. Reconciliation is a manual staff action.
NEXT_PUBLIC_ZELLE_HANDLE=""

# --- Twilio SMS (both apps) -------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
LEAD_NOTIFY_PHONE=""   # apps/corporate: Rasheen's number for new-lead SMS alerts
LEAD_NOTIFY_EMAIL=""   # apps/corporate: logged as a stub until a real email provider is wired up

# --- E-signature (apps/booking — rental agreements) -------------------------
ESIGNATURE_PROVIDER="docusign"   # "docusign" | "hellosign"
ESIGNATURE_API_KEY=""

# --- Live chat (both apps, pluggable) ---------------------------------------
NEXT_PUBLIC_CHAT_PROVIDER="stub"   # "stub" | "crisp" | "intercom"
NEXT_PUBLIC_CHAT_WIDGET_ID=""

# --- Maps (both apps) --------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Google Places Reviews (apps/corporate) ----------------------------------
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACES_PLACE_ID=""

# --- Analytics (both apps) ---------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
